# Variables de entorno para producción
# Copia este archivo como .env.production y ajusta los valores

# URL del backend de producción
VITE_API_BASE_URL=https://colegio-backend-ia.onrender.com

# Configuración de la aplicación
VITE_APP_NAME=Estud-IA
VITE_APP_VERSION=1.0.0

# Configuración de entorno
VITE_NODE_ENV=production

# Configuración de autenticación
VITE_TOKEN_EXPIRY=24h
VITE_ENABLE_DEBUG=false

# Configuración de PDF
VITE_PDF_ENABLED=true
VITE_PDF_SERVICE_URL=https://api.jshpdf.com

# Configuración de análisis (opcional)
# VITE_GOOGLE_ANALYTICS_ID=GA_MEASUREMENT_ID
# VITE_SENTRY_DSN=SENTRY_DSN_URL
